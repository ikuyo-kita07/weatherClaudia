<LinearLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:id="@+id/settingsWindow"
    android:background="@color/pitchBlackBackground"
    android:orientation="vertical"
    android:paddingBottom="40dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="64dp"
        android:text="@string/settings"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:fontFamily="@font/san_frans_display"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/san_frans"
        android:text="@string/settings_bottom_text"
        android:textColor="#99FFFFFF"
        android:textSize="15sp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="10dp"
        android:fontFamily="@font/san_frans"
        android:text="@string/general"
        android:textColor="#66FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:background="@drawable/glass_card"
        android:orientation="vertical"
        android:paddingVertical="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_temperature"
                app:tint="@android:color/white"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/tempFormats"
                android:fontFamily="@font/san_frans_pro_display_med"
                android:textColor="@android:color/white"
                android:textSize="17sp"/>
            <Spinner
                android:id="@+id/formattingTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="58dp"
            android:background="#22FFFFFF"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_palette"
                app:tint="@android:color/white"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/theme"
                android:fontFamily="@font/san_frans_pro_display_med"
                android:textColor="@android:color/white"
                android:textSize="17sp"/>
            <Spinner
                android:id="@+id/themesRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="58dp"
            android:background="#22FFFFFF"/>
        <LinearLayout
            android:id="@+id/manageCoordinates"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_location"
                app:tint="@android:color/white"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/location"
                android:fontFamily="@font/san_frans_pro_display_med"
                android:textColor="@android:color/white"
                android:textSize="17sp"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/right_arrow"
                app:tint="#66FFFFFF"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="10dp"
        android:fontFamily="@font/san_frans"
        android:text="@string/about"
        android:textColor="#66FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"/>
    <LinearLayout
        android:id="@+id/creditsWindow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="18dp"
        android:background="@drawable/glass_card"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_info"
            app:tint="@android:color/white"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/creds"
            android:fontFamily="@font/san_frans_pro_display_med"
            android:textColor="@android:color/white"
            android:textSize="17sp"/>
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/right_arrow"
            app:tint="#66FFFFFF"/>
    </LinearLayout>
</LinearLayout>